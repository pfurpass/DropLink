# Dependencies & build output
node_modules/
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files — contain secrets (JWT_SECRET, ADMIN_PASS, SMTP_PASS, etc.)
.env
.env.*
!.env.example
# Frontend .env only holds public URLs, keep tracked
!frontend/.env

# Local app data (generated at runtime)
backend/uploads/
backend/*.sqlite
backend/*.sqlite-journal

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
