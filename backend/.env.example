# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
MAX_FILE_SIZE_MB=512
# Public URL of the frontend — used to build download links in outgoing emails
APP_URL=http://localhost:5173

# ── Security ────────────────────────────────────────────────────────────────
# CHANGE BEFORE DEPLOYING. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Default admin user seeded on first run if the users table is empty.
# Log in once, then delete/rotate these credentials via the Users tab.
ADMIN_USER=admin
ADMIN_PASS=admin

# ── Database (only sqlite is implemented) ───────────────────────────────────
DB_TYPE=sqlite

# ── Authentication method (only local is implemented) ──────────────────────
AUTH_METHOD=local

# LDAP (requires server-side integration, not wired up yet)
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASS=

# SSO / OAuth (requires server-side integration, not wired up yet)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=

# ── Email / SMTP ────────────────────────────────────────────────────────────
# Set to true to enable sending download links by email from the upload form.
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
# true for implicit TLS (port 465), false for STARTTLS (port 587)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# The "From" address shown to recipients. Falls back to SMTP_USER if empty.
SMTP_FROM=
