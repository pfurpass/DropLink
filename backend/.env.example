# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
MAX_FILE_SIZE_MB=512

# ── Security ────────────────────────────────────────────────────────────────
# CHANGE BEFORE DEPLOYING. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Default admin user seeded on first run if the users table is empty.
# Log in once, then delete/rotate these credentials via the Users tab.
ADMIN_USER=admin
ADMIN_PASS=admin

# ── Database (only sqlite is implemented) ───────────────────────────────────
DB_TYPE=sqlite

# ── Authentication method (only local is implemented) ──────────────────────
AUTH_METHOD=local

# LDAP (requires server-side integration, not wired up yet)
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASS=

# SSO / OAuth (requires server-side integration, not wired up yet)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=
